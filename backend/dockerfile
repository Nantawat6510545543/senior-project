# 1. Use Python version 3.10.19 (slim is a smaller, optimized image)
FROM python:3.10.19-slim

# 2. Set the working directory
WORKDIR /code

# 3. Copy only requirements first (this optimizes Docker's build cache)
COPY requirements.txt .

# 4. Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# 5. Copy the rest of your backend code into the container
COPY . .

# 6. Expose the port your app runs on
EXPOSE 8000

# 7. Start the application
# Note: If your main python file isn't named "main.py", change "main:app" accordingly.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]