# ==========================================
# Backend Environment Variables
# Instructions: Copy this file, rename it to '.env', 
# and update the paths to match your local machine.
# ==========================================

# --- Local File Paths ---
# Provide the absolute paths on your actual computer.
# (If using Docker, these folders will automatically be mounted into the container).

# Absolute path to the HBN-EEG dataset directory
DATA_ROOT=/path/to/your/local/datasets/HBN-EEG

# Absolute path to where job outputs/logs should be saved
JOBS_ROOT=/path/to/your/local/senior-project/jobs


# --- Application URLs ---
# Note: For local development, keep these as localhost.

# URL where the frontend application is running
FRONTEND_URL=http://localhost:3000

# URL where the FastAPI backend is running
BACKEND_URL=http://localhost:8000