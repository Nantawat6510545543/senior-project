# ==========================================
# Backend Environment Variables
# Instructions: Copy this file, rename it to '.env', 
# and update the paths to match your local machine.
# ==========================================
# --- Local File Paths ---

# Absolute path to the HBN-EEG dataset directory
DATA_ROOT=/path/to/your/datasets/HBN-EEG

# Absolute path to job outputs/logs
JOBS_ROOT=/path/to/your/jobs


# --- Application URLs ---

# Frontend URL (local or deployed)
FRONTEND_URL=http://localhost:3000

# Backend URL (local or ngrok)
BACKEND_URL=http://localhost:8000


# --- ngrok Configuration ---

# Your ngrok reserved domain (if using custom domain)
NGROK_DOMAIN=your-ngrok-domain.ngrok-free.app

# Your ngrok auth token (required for reserved domains)
NGROK_AUTHTOKEN=your_ngrok_auth_token_here